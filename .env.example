# ─────────────────────────────────────────────────────────────
# Database — libSQL (SQLite locally, Turso in production)
# ─────────────────────────────────────────────────────────────

# Local development: a SQLite file in the project root. No account needed.
DATABASE_URL="file:./local.db"
DATABASE_AUTH_TOKEN=""

# Production (Turso — free tier): create a database at https://turso.tech
# and set these to its URL + auth token, e.g.
#   DATABASE_URL="libsql://your-db-name-you.turso.io"
#   DATABASE_AUTH_TOKEN="eyJhbGciOi..."

# ─────────────────────────────────────────────────────────────
# Auth.js (Google sign-in, one private diary per account)
# ─────────────────────────────────────────────────────────────

# Required. Generate one with:  npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=""

# Google OAuth credentials — Google Cloud Console → APIs & Services →
# Credentials → Create OAuth client ID → "Web application".
# Authorized redirect URI:  https://<your-domain>/api/auth/callback/google
#                  (local)  http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# In local dev only, an email-only "Dev sign in" is available without Google,
# so you can test before setting the credentials above. It is disabled in
# production automatically.
